{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "core:window:allow-set-title",
    "dialog:default",
    "opener:default",
    "fs:default",
    {
      "identifier": "fs:allow-watch",
      "allow": [{ "path": "**" }]
    },
    "updater:default",
    "process:allow-restart",
    "log:default"
  ]
}
