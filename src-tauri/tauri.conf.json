{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "grimoire",
  "version": "0.1.0",
  "identifier": "com.lamonta.grimoire",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Grimoire",
        "width": 1280,
        "height": 832,
        "minWidth": 1024,
        "minHeight": 768,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczNDY2ODk1QUM5NjZDRTcKUldUbmJKYXNsV2hHY3dERXFpeG5xY2NqVXFsRjFZZlpkc1NlbjdSS09OMndsdy80YmI2RkFjOG0K",
      "endpoints": [
        "https://github.com/Larront/grimoire/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": ["sample-world/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
