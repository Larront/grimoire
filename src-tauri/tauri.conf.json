{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "grimoire",
  "version": "../package.json",
  "identifier": "com.lamonta.grimoire",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Grimoire",
        "width": 1280,
        "height": 832,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' 'wasm-unsafe-eval' https://sdk.scdn.co",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost data: blob:",
        "media-src": "'self' asset: http://asset.localhost blob: https://*.spotify.com https://*.scdn.co",
        "font-src": "'self' data:",
        "connect-src": "'self' ipc: http://ipc.localhost asset: http://asset.localhost https://*.spotify.com wss://*.spotify.com https://*.scdn.co",
        "worker-src": "'self' blob:",
        "frame-src": "https://sdk.scdn.co",
        "object-src": "'none'"
      },
      "devCsp": {
        "default-src": "'self'",
        "script-src": "'self' 'unsafe-eval' 'wasm-unsafe-eval' https://sdk.scdn.co",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost data: blob:",
        "media-src": "'self' asset: http://asset.localhost blob: https://*.spotify.com https://*.scdn.co",
        "font-src": "'self' data:",
        "connect-src": "'self' ipc: http://ipc.localhost asset: http://asset.localhost ws://localhost:1420 http://localhost:1420 https://*.spotify.com wss://*.spotify.com https://*.scdn.co",
        "worker-src": "'self' blob:",
        "frame-src": "https://sdk.scdn.co",
        "object-src": "'none'"
      },
      "dangerousDisableAssetCspModification": ["style-src"],
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczNDY2ODk1QUM5NjZDRTcKUldUbmJKYXNsV2hHY3dERXFpeG5xY2NqVXFsRjFZZlpkc1NlbjdSS09OMndsdy80YmI2RkFjOG0K",
      "endpoints": [
        "https://github.com/Larront/grimoire/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": ["sample-world/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
